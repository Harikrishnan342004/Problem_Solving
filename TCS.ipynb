    "#Reverse The Sentence By using python\n",
    "def reverse_sentence(S):\n",
    "    result = []\n",
    "    sp = S.split()\n",
    "    \n",
    "    for i in sp:\n",
    "        result = [i] + result\n",
    "    return \" \".join(result)\n",
    "S = \"Hari Santhiya\"\n",
    "Output = reverse_sentence(S)\n",
    "print(Output)"
   ]
  }
