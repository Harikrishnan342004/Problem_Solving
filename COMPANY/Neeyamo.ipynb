    "#Neeyamo....\n",
    "#resverse the words in the sentence\n",
    "def reverse(s):\n",
    "    result = []\n",
    "    splitting = s.split()\n",
    "    # print(splitting)\n",
    "    for char in splitting:\n",
    "        result = [char] + result\n",
    "\n",
    "    return \" \".join(result)\n",
    "s = \"geeks quiz practice code\"\n",
    "Output = reverse(s)\n",
    "print(Output)\n"
   ]
